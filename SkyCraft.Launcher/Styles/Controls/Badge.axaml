<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Стили бейджей/чипсов -->
    
    <Style Selector="Border.Badge">
        <Setter Property="Background" Value="{StaticResource ColorPrimaryDark}"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="5"/>
    </Style>
    
    <Style Selector="TextBlock.BadgeName">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextWhite}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    
    <Style Selector="TextBlock.BadgeText">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextLight}"/>
    </Style>
    
    <Style Selector="TextBlock.BadgeDesc">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextLight}"/>
        <Setter Property="Opacity" Value="0.6"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
</Styles>