<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Стили списков -->
    
    <Style Selector="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="ClipToBounds" Value="False"/>

        <Style Selector="^ ScrollViewer">
            
            <Setter Property="ClipToBounds" Value="False"/>
        </Style>
        <Style Selector="^ ListBoxItem">
            <Setter Property="ClipToBounds" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            
            <Style Selector="^ Border#PART_Border">
                <Setter Property="RenderTransform" Value="translateX(0px)" />
                <Setter Property="Background" Value="{StaticResource ColorBgCard}" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Effect" Value="{StaticResource EffectDefault}" />
                
                <Setter Property="Transitions">
                    <Transitions>
                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
                        <BrushTransition Property="Background" Duration="0:0:0.3"/>
                        <EffectTransition Property="Effect" Duration="0:0:0.3"/>
                    </Transitions>
                </Setter>
            </Style>
            
            <Style Selector="^:pointerover /template/ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
            </Style>
            
            <Style Selector="^:pointerover Border#PART_Border">
                <Setter Property="RenderTransform" Value="translateX(5px)" />
                <Setter Property="Background" Value="#2b1550" />
                <Setter Property="Effect" Value="{StaticResource EffectShadow}" />
            </Style>
            
            <Style Selector="^:selected /template/ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
            </Style>
            
            <Style Selector="^:selected Border#PART_Border">
                <Setter Property="RenderTransform" Value="translateX(5px)" />
                <Setter Property="Background" Value="{StaticResource BrushSelected}" />
                <Setter Property="Effect" Value="{StaticResource EffectFocused}" />
            </Style>
        </Style>
    </Style>
</Styles>