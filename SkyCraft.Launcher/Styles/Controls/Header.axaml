<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Стили хедера: логотип, никнейм -->
    
    <Style Selector="TextBlock.LogoText">
        <Setter Property="FontSize" Value="25" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource BrushLogo}" />
    </Style>

    <Style Selector="TextBlock.Nickname">
        <Setter Property="FontSize" Value="15" />
    </Style>
    
    <Style Selector="Border.LogoCloud">
        <Setter Property="Effect" Value="{StaticResource EffectGlow}" />
    </Style>
</Styles>