<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SkyCraft.Launcher.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:SkyCraft.Launcher.Views.Controls"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SkyCraft.Launcher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/icon.ico"
        Title="SkyCraft"
        WindowDecorations="None"
        Width="1200"
        Height="700">

    <Border Classes="Background">
        <Grid RowDefinitions="50 *">
            
            <Border Grid.Row="0" Grid.RowSpan="2"
                    Classes.BorderDarkGlass="{Binding OverlayVisible}">
                <ContentControl Content="{Binding CurrentPage}"  Margin="20 60 20 20 "/>
            </Border>
            <Border Grid.Row="0" Grid.RowSpan="2"
                    IsVisible="{Binding OverlayVisible}"
                    Opacity="{Binding CurrentOverlay?.Opacity}"
                    Classes="BorderOpacity">
                <ContentControl Content="{Binding CurrentOverlay}"/>
            </Border>
            <ContentControl Grid.Row="0" Content="{Binding TitleBar}"/>
        </Grid>
    </Border>
</Window>
