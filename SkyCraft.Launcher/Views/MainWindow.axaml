<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SkyCraft.Launcher.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:SkyCraft.Launcher.Views.Controls"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SkyCraft.Launcher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SkyCraft"
        WindowDecorations="None">

    <Grid RowDefinitions="50 *">
        <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" 
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="20 0 20 20" />
        <ContentControl Grid.Row="0" Grid.RowSpan="2" Content="{Binding CurrentOverlay}" 
                        HorizontalAlignment="Center" VerticalAlignment="Center" />
        
        <ContentControl Grid.Row="0" Content="{Binding TitleBar}"/>
    </Grid>

</Window>
